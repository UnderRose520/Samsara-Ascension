; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="轮回仙途"
config/description="Samsara Ascension"
run/main_scene="res://scenes/main/main.tscn"
config/features=PackedStringArray("4.6", "Forward Plus")
run/max_fps=60
config/icon="res://icon.svg"

[autoload]

EventBus="*res://autoload/event_bus.gd"
ConfigRegistry="*res://autoload/config_registry.gd"
SaveManager="*res://autoload/save_manager.gd"
RunContext="*res://autoload/run_context.gd"
CombatRngService="*res://autoload/combat_rng_service.gd"
EntityCache="*res://autoload/entity_cache.gd"
SpellProgress="*res://autoload/spell_progress.gd"
KarmaTracker="*res://autoload/karma_tracker.gd"
CombatSpawner="*res://autoload/combat_spawner.gd"
WeatherSystem="*res://systems/world/weather_system.gd"
TerrainSystem="*res://systems/world/terrain_system.gd"
VfxManager="*res://autoload/vfx_manager.gd"
AudioManager="*res://autoload/audio_manager.gd"
RunDirector="*res://systems/world/run_director.gd"
HiddenChainDetector="*res://systems/world/hidden_chain_detector.gd"
BattleEventDirector="*res://systems/world/battle_event_director.gd"

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
window/size/window_width_override=1920
window/size/window_height_override=1080
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"
window/stretch/scale_mode="fractional"

[editor_plugins]

enabled=PackedStringArray("res://addons/godot_mcp/plugin.cfg")

[gui]

theme/custom="res://ui/theme/samsara_theme.tres"

